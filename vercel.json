{
    "cleanUrls": true,
    "outputDirectory": ".",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {"key": "Access-Control-Allow-Origin", "value": "*"},
                {"key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"} ]
        },
        {
            "source": "/articles/blob/(.*)/(.*).md",
            "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
        }
    ]
}